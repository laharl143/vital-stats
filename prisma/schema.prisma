// ============================================================
// VitalStats — Prisma Schema
// Database: PostgreSQL
// ORM: Prisma
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Category {
  WEIGHT_MANAGEMENT
  RECOVERY_ANTI_AGING
  SKIN_CARE
  MEDICAL_CONSULTATION
}

enum DeliveryMethod {
  INJECTION       // e.g. Tirzepatide, NAD+, GHK-Cu
  TOPICAL         // e.g. Luméla soap, lotion, serum
  ORAL            // future-proofing
  CONSULTATION    // service, not a physical product
}

enum InquiryType {
  PRODUCT_AVAILABILITY
  PROGRAM_GUIDANCE
  ORDER_INQUIRY
  GENERAL
}

enum InquiryStatus {
  NEW
  READ
  RESPONDED
  CLOSED
}

enum OrderStatus {
  PENDING          // inquiry received, not yet confirmed
  CONFIRMED        // admin confirmed availability
  PROCESSING       // being prepared
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

// ─────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────

model Product {
  id              String         @id @default(cuid())
  slug            String         @unique  // URL-friendly: "tirzepatide", "nad-plus"
  name            String
  tagline         String?        // short hook, e.g. "Once-a-week weight loss injection"
  description     String         // main body text (markdown supported)
  howItWorks      String?        // mechanism / science section
  howAdministered String?        // injection site info, dosage notes
  warnings        String?        // ⚠️ medical supervision notices
  category        Category
  deliveryMethod  DeliveryMethod
  price           Decimal?       @db.Decimal(10, 2)  // null for consultation / injectable (price on inquiry)
  currency        String         @default("PHP")
  isBestSeller    Boolean        @default(false)
  isFdaApproved   Boolean        @default(false)
  isClinicallyGuided Boolean     @default(false)
  requiresPrescription Boolean   @default(false)
  isActive        Boolean        @default(true)
  sortOrder       Int            @default(0)

  images          ProductImage[]
  ingredients     ProductIngredient[]
  benefits        ProductBenefit[]
  orderItems      OrderItem[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([category])
  @@index([isActive])
}

model ProductImage {
  id          String   @id @default(cuid())
  productId   String
  url         String   // Cloudinary URL
  publicId    String   // Cloudinary public_id (for deletion)
  alt         String?
  isPrimary   Boolean  @default(false)
  sortOrder   Int      @default(0)

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductIngredient {
  id          String   @id @default(cuid())
  productId   String
  name        String   // e.g. "Kojic Acid", "Niacinamide", "5x Ceramides"
  role        String?  // what it does, one line

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model ProductBenefit {
  id          String   @id @default(cuid())
  productId   String
  benefit     String   // e.g. "Make you feel full faster"
  sortOrder   Int      @default(0)

  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
}

// ─────────────────────────────────────────
// INQUIRY (contact form)
// ─────────────────────────────────────────

model Inquiry {
  id          String        @id @default(cuid())
  name        String
  contactInfo String        // phone or Facebook name / messenger link
  message     String
  type        InquiryType   @default(GENERAL)
  status      InquiryStatus @default(NEW)
  adminNotes  String?       // internal notes from the VitalStats team
  productId   String?       // optional: which product they're asking about
  ipAddress   String?       // for spam detection

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([status])
  @@index([createdAt])
}

// ─────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique @default(cuid()) // human-readable ref
  customerName    String
  customerContact String      // phone or messenger
  customerAddress String?
  status          OrderStatus @default(PENDING)
  notes           String?     // special instructions
  adminNotes      String?
  totalAmount     Decimal?    @db.Decimal(10, 2)
  currency        String      @default("PHP")

  items           OrderItem[]

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String   // snapshot at order time (in case product is later renamed)
  quantity    Int      @default(1)
  unitPrice   Decimal? @db.Decimal(10, 2)

  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product  @relation(fields: [productId], references: [id])

  @@index([orderId])
}

// ─────────────────────────────────────────
// ADMIN USER (NextAuth)
// ─────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          Role      @default(ADMIN)

  accounts      Account[]
  sessions      Session[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum Role {
  ADMIN
  SUPER_ADMIN
}

// NextAuth required models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
